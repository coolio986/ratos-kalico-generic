# ratos-kalico-generic — install configuration
# Sourced by install.sh and every step. Override before running if needed.

# --- User / paths -----------------------------------------------------------
# RatOS scripts hardcode /home/pi in many places. Keep the user as 'pi'.
RK_USER="${RK_USER:-pi}"
RK_HOME="/home/${RK_USER}"
RK_PRINTER_DATA="${RK_HOME}/printer_data"
RK_CONFIG="${RK_PRINTER_DATA}/config"

# --- Forks (your GitHub) ----------------------------------------------------
RK_GH_OWNER="${RK_GH_OWNER:-coolio986}"

RK_CONFIGURATION_REPO="https://github.com/${RK_GH_OWNER}/RatOS-configuration.git"
RK_CONFIGURATION_BRANCH="v2.1.x"

RK_CONFIGURATOR_REPO="https://github.com/${RK_GH_OWNER}/RatOS-configurator.git"
RK_CONFIGURATOR_BRANCH="v2.1.x-deployment"

RK_THEME_REPO="https://github.com/${RK_GH_OWNER}/RatOS-theme.git"
RK_THEME_BRANCH="v2.1.x"

# --- Base (installed by KIAUH before this runs) -----------------------------
# Kalico == Danger-Klipper. KIAUH can install it via a custom repo override.
RK_KALICO_REPO="https://github.com/KalicoCrew/kalico.git"
RK_KLIPPER_DIR="${RK_HOME}/klipper"        # KIAUH keeps the dir named 'klipper'
RK_KLIPPY_ENV="${RK_HOME}/klippy-env"
RK_MOONRAKER_DIR="${RK_HOME}/moonraker"
RK_MAINSAIL_DIR="${RK_HOME}/mainsail"

# --- Extras -----------------------------------------------------------------
RK_BEACON_REPO="https://github.com/beacon3d/beacon_klipper.git"
RK_LMA_REPO="https://github.com/worksasintended/klipper_linear_movement_analysis.git"

# --- Configurator runtime ---------------------------------------------------
RK_CONFIGURATOR_DIR="${RK_HOME}/ratos-configurator"
RK_CONFIGURATOR_PORT="3000"
RK_NODE_MAJOR="20"                          # LTS; configurator is a Next.js app
